datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

model User {
  id       String  @id @default(uuid())
  name     String
  password String?
  phone    String? @unique
  email    String? @unique
  photo    String?
  location String?
  lat      Float?
  lng      Float?

  // Stored as JSON strings
  sports    String? // JSON array ["football", "cricket"]
  positions String? // JSON object {"football": "Striker"}
  ratings   String? // JSON object {"football": {...}}

  trustScore  Int    @default(0)
  gamesPlayed Int    @default(0)
  wins        Int    @default(0)
  losses      Int    @default(0)
  draws       Int    @default(0)
  privacy     String @default("public")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizedGames Game[]         @relation("Organizer")
  rsvps          Rsvp[]
  notifications  Notification[]

  thoughtsSent     Thought[] @relation("ThoughtSender")
  thoughtsReceived Thought[] @relation("ThoughtReceiver")

  friendshipsInitiated Friendship[] @relation("FriendshipInitiator")
  friendshipsReceived  Friendship[] @relation("FriendshipReceiver")

  friendTiers FriendTier[] @relation("TierOwner")

  sentInvites     FriendInvite[] @relation("FriendInviteSender")
  receivedInvites FriendInvite[] @relation("FriendInviteFriend")
  friendsAsUser   Friend[]       @relation("FriendUser")
  friendsAsFriend Friend[]       @relation("FriendFriend")
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("accepted") // pending, accepted
  createdAt DateTime @default(now())

  user   User @relation("FriendshipInitiator", fields: [userId], references: [id])
  friend User @relation("FriendshipReceiver", fields: [friendId], references: [id])

  @@unique([userId, friendId])
  @@index([friendId])           // for reverse lookups in OR queries
  @@index([userId, status])     // fast filter: my accepted friends
  @@index([friendId, status])   // fast filter: requests sent to me
}

model FriendTier {
  id       String @id @default(uuid())
  userId   String
  friendId String
  sport    String
  tier     Int // 1, 2, 3

  user User @relation("TierOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId, sport])
  @@index([userId]) // fetch all tiers for a user
}

model Friend {
  id           String   @id @default(uuid())
  userId       String
  friendUserId String
  phone        String?
  createdAt    DateTime @default(now())
  user         User     @relation(name: "FriendUser", fields: [userId], references: [id])
  friend       User     @relation(name: "FriendFriend", fields: [friendUserId], references: [id])

  @@unique([userId, friendUserId])
  @@index([userId])
}

model FriendInvite {
  id       String   @id @default(uuid())
  senderId String
  friendId String
  phone    String?
  message  String?
  sentAt   DateTime @default(now())
  method   String // "app" | "sms"
  sender   User     @relation(name: "FriendInviteSender", fields: [senderId], references: [id])
  friend   User     @relation(name: "FriendInviteFriend", fields: [friendId], references: [id])

  @@index([senderId])
  @@index([friendId])
}

model Thought {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  text      String
  createdAt DateTime @default(now())

  sender   User @relation("ThoughtSender", fields: [fromId], references: [id])
  receiver User @relation("ThoughtReceiver", fields: [toId], references: [id])

  @@index([toId])   // thoughtsReceived lookup
  @@index([fromId]) // thoughtsSent lookup
}

model Game {
  id               String  @id @default(uuid())
  title            String
  sport            String
  format           String
  date             String
  time             String
  duration         Int
  location         String
  lat              Float?
  lng              Float?
  address          String?
  maxPlayers       Int
  skillLevel       String
  status           String  @default("open") // open | completed | cancelled
  visibility       String  @default("public") // public | friends | private
  approvalRequired Boolean @default(false)
  bookingImage     String?

  pitchType String?
  surface   String?
  footwear  String?
  price     Float?  @default(0)
  gender    String  @default("mixed")
  amenities String?

  reminderHours Int     @default(2)
  remindersSent Boolean @default(false)

  organizerId String
  organizer   User   @relation("Organizer", fields: [organizerId], references: [id], onDelete: Cascade)

  rsvps         Rsvp[]
  notifications Notification[]

  createdAt DateTime @default(now())

  @@index([organizerId])        // organizer's games
  @@index([status])             // filter by open/completed
  @@index([date])               // date-range queries & auto-expire
  @@index([sport])              // sport filter
  @@index([status, date])       // composite: auto-expire (open games before date)
  @@index([visibility, status]) // discover: public open games
}

model Rsvp {
  id        String   @id @default(uuid())
  gameId    String
  playerId  String
  status    String // 'yes', 'no', 'backup', 'maybe'
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player User @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId]) // also acts as index on (gameId, playerId)
  @@index([playerId])          // all games a player has RSVPed for
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  action    String?
  gameId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game? @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])        // all notifications for a user
  @@index([userId, read])  // unread notifications for a user
}
