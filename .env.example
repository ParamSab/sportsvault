# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/sportsvault

# Session (must be at least 32 characters)
SESSION_SECRET=replace-with-a-random-secret-min-32-chars!!

# Twilio Verify (for phone/SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (for email OTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (for game save persistence & history)
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Use the service_role key on the server for full DB access (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
