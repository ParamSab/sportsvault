# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sportsvault

# Session (must be at least 32 characters)
SESSION_SECRET=replace-with-a-random-secret-min-32-chars!!

# Twilio Verify (for phone/SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (for email OTP)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
